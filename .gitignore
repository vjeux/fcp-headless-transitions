# Build artifacts
oz_render.dylib
*.dylib
*.o

# Python venv (machine-specific; recreate via setup — see README)
venv/

# Browser engine (engine/) node deps
node_modules/

# Render outputs (headless + run_all + engine GT), and large media
out/
all_out/
engine/test/ground-truth/
*.mp4
*.mov

# macOS
.DS_Store

# Python cache
__pycache__/
*.pyc
montage.mp4
tools/__pycache__/
fct/__pycache__/
.fctcache/

# minimizer scratch (per-case slug map written by min-gen; the case.motr + frames commit)
fct/minimized/*/_slugmap.json

# swarm agent scratch (per-worktree prompt files + runner + local frames)
.swarm_brief.md
.swarm_reflect_prompt.md
.swarm_run.sh
.frames/
# swarm worktrees symlink node_modules/venv (the trailing-slash rules above match
# DIRECTORIES only, not the symlinks), so match them without a slash too:
engine/node_modules
/venv

# Minimized delta-debug cases (fct/minimized/<case>/): COMMIT case.motr + manifest.json
# + headless/ (the frozen FCP truth — can't be regenerated without FCP). The engine/
# frames are re-rendered by `fct min-gen`, and _slugmap.json is scratch → ignore both.
fct/minimized/*/engine/
fct/minimized/*/_slugmap.json
